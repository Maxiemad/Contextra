# Free local LLM — copy to .env:  cp ollama.env .env
# Requires: https://ollama.com  →  ollama pull llama3.2  →  keep Ollama running

LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
# OLLAMA_VISION_MODEL=llava
# OLLAMA_VISION_TIMEOUT_SEC=90
# USE_OLLAMA_VISION=true

# No OpenAI needed for chat/embeddings when empty (SentenceTransformers used for vectors)
OPENAI_API_KEY=

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
