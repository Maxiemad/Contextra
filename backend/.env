# ================================================================
# Contextra backend configuration
# ================================================================

# ---- LLM ----
# auto = Ollama if reachable, else Groq (recommended)
# ollama = Ollama only (local dev)
# groq   = Groq only  (Render / prod)
LLM_BACKEND=auto

# Groq (https://console.groq.com/keys) — required for cloud deploy
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Ollama (local)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_VISION_MODEL=llava
# How long (seconds) to wait when probing whether Ollama is up. Default 1.5
# OLLAMA_PROBE_TIMEOUT=1.5
# Per-request LLM timeout. Default 60
# LLM_REQUEST_TIMEOUT=60

# ---- Embeddings (always local, free) ----
ST_MODEL_NAME=all-MiniLM-L6-v2

# ---- Storage ----
# On Render free tier, point to /tmp (ephemeral but writable).
# Locally, leave unset to use repo-root data/
# DATA_ROOT=/tmp/contextra_data

# ---- Auth (optional) ----
# If set, all routes except GET / and /health require X-API-Key or Authorization: Bearer
# API_KEY=

# ---- CORS ----
# Deployed frontend URL (no trailing slash). Automatically added to allowed origins.
FRONTEND_URL=https://contextra-1.onrender.com
# Extra origins (comma-separated). Keep localhost for dev.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173