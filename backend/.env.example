# --- LLM for chat ---
# FREE (no API key): install https://ollama.com then: ollama pull llama3.2
# Images/charts: also  ollama pull llava   (or set OLLAMA_VISION_MODEL)
# LLM_BACKEND=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_VISION_MODEL=llava

# Option A: OpenAI
OPENAI_API_KEY=
# Option B: Hugging Face Inference API
# HUGGINGFACEHUB_API_TOKEN=hf_...

# LLM_BACKEND=auto
# auto = OpenAI → Hugging Face → Ollama (free local)
# LLM_BACKEND=openai
# LLM_BACKEND=huggingface
# HF_CHAT_REPO_ID=HuggingFaceH4/zephyr-7b-beta

# Optional: OpenAI-compatible proxy
# OPENAI_BASE_URL=https://api.openai.com/v1

OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Set to true to use Sentence Transformers instead of OpenAI embeddings (offline indexing)
# USE_SENTENCE_TRANSFORMERS=false

# When set, all API routes except GET /health require X-API-Key or Authorization: Bearer
# API_KEY=

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173